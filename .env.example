# Copy to .env (gitignored) and fill in. Used by build/refresh.sh and the fetcher.
# Both are optional: without a key the fetcher uses OpenAlex's rate-limited public
# pool. With a key (OpenAlex Premium) it runs reliably and fast.

OPENALEX_API_KEY=
# Contact email for the OpenAlex polite pool (not the maintainer's personal email).
OPENALEX_MAILTO=
